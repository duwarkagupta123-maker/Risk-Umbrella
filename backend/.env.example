# Server
PORT=5000

# MongoDB Atlas connection string (replace user, password, cluster)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/risk_umbrella?retryWrites=true&w=majority

# JWT signing secret – use a long random string in production
JWT_SECRET=your_super_secret_key_change_this

# Primary frontend origin (comma-separated for multiple: url1,url2)
FRONTEND_URL=http://localhost:5173,https://risk-umbrella.netlify.app
